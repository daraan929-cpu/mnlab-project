# MNLAB Environment Variables Example
# Copy this file to .env and fill in your keys

# --- MongoDB (Free from MongoDB Atlas) ---
# Example: mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_URL=

# --- Cloudinary (Free from Cloudinary.com) ---
# Example: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=

# --- Admin Password ---
# Optional: Set a custom admin password for the dashboard
# ADMIN_PASSWORD=admin123

# --- Server Port ---
PORT=8000
